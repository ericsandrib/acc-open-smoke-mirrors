# Schwab developer portal credentials
# Get these from https://developer.schwab.com → My Apps → your app.
#
# While these two are missing, the proxy runs in MOCK MODE: the UI works end-to-end,
# "Send to Schwab" returns a synthetic 204 with a fresh correlation ID, and nothing
# is actually sent to Schwab. Set both values and restart `pnpm server` to go live.
SCHWAB_CLIENT_ID=
SCHWAB_CLIENT_SECRET=

# Base URL. Keep the default unless Schwab provides a different sandbox host.
SCHWAB_BASE_URL=https://api.schwabapi.com

# OAuth callback. Must match exactly what's registered in the Schwab dev portal.
# If you change PORT below, update this too.
SCHWAB_CALLBACK_URL=http://localhost:3001/api/schwab/oauth/callback

# Where Vite serves the frontend (used for CORS + OAuth redirect back into app).
FRONTEND_ORIGIN=http://localhost:5173

# Proxy port. Keep 3001 unless something else is already bound.
PORT=3001

# Force mock mode even when creds are present (useful for offline demos).
# SCHWAB_MOCK=1
